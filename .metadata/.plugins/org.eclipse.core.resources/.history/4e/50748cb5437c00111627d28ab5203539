package com.abc;
import java.util.*;
public class new_triangle {
  public static void main(String[] args) {
	Scanner scanner = new Scanner(System.in);
	int n= scanner.nextInt();
	
	for(int i=0;i<=n;i++) {
		for(int j=1;j<=n/2;j++) {
			System.out.print("");
		}
		for(int k=1;k<=i;k++) {
			System.out.print("*");
		}
		for(int j=1;j<=n/2;j++) {
			System.out.print("");
		}
		System.out.println();
	}
  }
};
